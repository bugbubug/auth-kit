{
  "name": "@bugbubug/auth-kit",
  "version": "1.0.0",
  "description": "Pure, hexagonal, framework-agnostic auth verification (Email OTP + Google id_token) — verifies control of an identifier and returns a single VerifiedIdentity. No users/sessions/cookies.",
  "license": "MIT",
  "author": "bugbubug",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapters": "./src/adapters/index.ts",
    "./zod": "./src/zod.ts"
  },
  "files": [
    "src",
    "docs",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "jose": "^6.0.0"
  },
  "peerDependencies": {
    "zod": "^3.24.1"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
